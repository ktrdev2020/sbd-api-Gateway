{
  "name": "Gateway",
  "projectType": "application",
  "sourceRoot": ".",
  "targets": {
    "serve": {
      "command": "dotnet watch run --project Gateway.csproj --no-hot-reload",
      "continuous": true
    },
    "stop": {
      "command": "powershell -Command \"Get-Process -Name Gateway -EA SilentlyContinue | Stop-Process -Force\""
    },
    "db-migrate": {
      "command": "dotnet ef database update --startup-project Gateway.csproj"
    },
    "db-migration-add": {
      "command": "dotnet ef migrations add {args} --startup-project Gateway.csproj --output-dir Data/Migrations"
    }
  }
}
