{
  "name": "Gateway",
  "projectType": "application",
  "sourceRoot": "apps/dotnet/Gateway",
  "targets": {
    "build": {
      "command": "dotnet build apps/dotnet/Gateway/Gateway.csproj",
      "dependsOn": ["auth-service:build"]
    },
    "serve": {
      "command": "dotnet watch run --project apps/dotnet/Gateway/Gateway.csproj --no-hot-reload",
      "continuous": true
    },
    "stop": {
      "command": "powershell -Command \"Get-Process -Name Gateway -EA SilentlyContinue | Stop-Process -Force\""
    },
    "db-migrate": {
      "command": "dotnet ef database update --project libs/dotnet/SBD.Infrastructure/SBD.Infrastructure.csproj --startup-project apps/dotnet/Gateway/Gateway.csproj"
    }
  }
}
